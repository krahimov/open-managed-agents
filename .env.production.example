# OpenHarness production environment — copy to your host's secret manager
# (Railway/Fly env vars, not a file in the image). Every var here is read by
# apps/main-node at boot; main-node also auto-loads .env/.env.local from its
# working directory, so NEVER bake those files into a production image.

# ── Required ────────────────────────────────────────────────────────────────
# Sessions + at-rest encryption for model-card keys, vault credentials, and
# webhook signing secrets. Generate: openssl rand -base64 32
# BACK THIS UP — losing it bricks every encrypted credential.
PLATFORM_ROOT_SECRET=

# Better Auth session signing. Generate: openssl rand -hex 32
BETTER_AUTH_SECRET=

# Managed Postgres DSN (Railway/Fly/Neon/RDS). Leave unset only for
# single-box SQLite trials.
DATABASE_URL=postgres://user:pass@host:5432/openharness

# Cookie domain + OAuth redirect base + trusted origins.
PUBLIC_BASE_URL=https://app.yourdomain.com

# ── Sandboxing (pick an isolated provider for multi-tenant) ────────────────
# subprocess = NO isolation; fine for a single trusted operator only.
SANDBOX_PROVIDER=daytona
DAYTONA_API_KEY=
DAYTONA_API_URL=

# ── Optional: Google sign-in (Better Auth) ─────────────────────────────────
# Google Cloud Console -> OAuth client (Web). Authorized redirect URI:
#   https://app.yourdomain.com/auth/callback/google
# Setting both vars enables the provider automatically.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: require verified emails (adds email-otp provider).
# AUTH_REQUIRE_EMAIL_VERIFY=1

# ── Console UI ──────────────────────────────────────────────────────────────
# Set by the Dockerfile; override only if serving the SPA elsewhere.
# CONSOLE_DIR=/app/apps/console/dist

# ── MUST NOT BE SET IN PRODUCTION ──────────────────────────────────────────
# AUTH_DISABLED=1                 -> disables ALL auth incl. API-key checks
# OMA_DEFAULT_HARNESS=...         -> would route tenants to a default harness
# OMA_ENABLE_CLAUDE_AGENT_SDK=1   -> runs Claude Code ON THE HOST (self-host
#                                    single-operator feature; never hosted)
# WEBHOOKS_ALLOW_PRIVATE=1        -> disables the webhook SSRF guard
# ANTHROPIC_API_KEY               -> not needed; tenants bring keys via
#                                    Model Cards (encrypted per-tenant)
